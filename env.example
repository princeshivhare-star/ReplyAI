# ── Add ALL of these in Vercel Dashboard → Settings → Environment Variables ──

# Make this up yourself — any random string
WEBHOOK_VERIFY_TOKEN=replyai_secret_make_this_random_xyz

# From Meta App Dashboard → Settings → Basic
META_APP_SECRET=your_meta_app_secret_here

# Numeric Instagram Business Account ID
# Find it: graph.facebook.com/me?fields=id&access_token=YOUR_TOKEN
INSTAGRAM_ACCOUNT_ID=17841234567890

# From Meta App → Instagram → User Token Generator
INSTAGRAM_ACCESS_TOKEN=IGQVJxxxxxxxx

# Optional — for Facebook Page comments/Messenger
FACEBOOK_PAGE_ID=123456789012345
FACEBOOK_ACCESS_TOKEN=EAAxxxxxxxx
